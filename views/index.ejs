<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="header">
    <div class="container header-inner">
      <div class="logo">
        <span class="logo-icon">&#9670;</span>
        <span class="logo-text">Web2App</span>
      </div>
      <nav class="nav">
        <a href="#features">功能特性</a>
        <a href="#guide">使用指南</a>
        <a href="https://github.com" target="_blank" class="nav-github">GitHub</a>
      </nav>
    </div>
  </header>

  <!-- 英雄区域 -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">将网站一键封装为<br><span class="gradient-text">安卓应用</span></h1>
      <p class="hero-desc">输入网址、上传图标，60秒内生成可安装的APK文件。无需编程知识，零门槛操作。</p>
      <a href="#creator" class="btn-primary btn-lg hero-cta">立即开始制作 &rarr;</a>
      <div class="hero-stats">
        <div class="stat"><span class="stat-num">60s</span><span class="stat-label">极速生成</span></div>
        <div class="stat"><span class="stat-num">7.0+</span><span class="stat-label">Android兼容</span></div>
        <div class="stat"><span class="stat-num">100%</span><span class="stat-label">免费使用</span></div>
      </div>
    </div>
  </section>

  <!-- 三步流程 -->
  <section class="steps-section" id="features">
    <div class="container">
      <h2 class="section-title">三步完成封装</h2>
      <p class="section-subtitle">简单直观的操作流程，无需任何技术背景</p>
      <div class="steps-flow">
        <div class="step-card" data-step="1">
          <div class="step-number">1</div>
          <div class="step-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          </div>
          <h3>输入网址</h3>
          <p>输入您要封装的网站地址，系统自动验证可访问性</p>
        </div>
        <div class="step-connector"></div>
        <div class="step-card" data-step="2">
          <div class="step-number">2</div>
          <div class="step-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <h3>上传图标</h3>
          <p>上传应用图标，系统自动生成多尺寸适配</p>
        </div>
        <div class="step-connector"></div>
        <div class="step-card" data-step="3">
          <div class="step-number">3</div>
          <div class="step-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <h3>下载APK</h3>
          <p>一键生成安装包，扫码即可下载安装</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 核心操作区域 -->
  <section class="creator-section" id="creator">
    <div class="container">
      <h2 class="section-title">创建您的应用</h2>
      <p class="section-subtitle">填写以下信息，系统将自动为您生成安卓安装包</p>

      <div class="creator-layout">
        <!-- 左侧：操作面板 -->
        <div class="creator-main">

          <!-- 步骤1：网址输入 -->
          <div class="form-section" id="section-url">
            <div class="section-header">
              <div class="section-badge">步骤 1</div>
              <h3 class="section-heading">输入网站地址</h3>
              <button class="help-btn" data-help="url-help" aria-label="帮助">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </button>
            </div>

            <!-- 帮助提示气泡 -->
            <div class="help-tooltip" id="url-help">
              <div class="help-tooltip-arrow"></div>
              <div class="help-tooltip-content">
                <strong>网址输入说明</strong>
                <ul>
                  <li>支持 HTTP 和 HTTPS 协议</li>
                  <li>建议使用 HTTPS 以获得更好的安全性</li>
                  <li>系统会自动检测网站是否可访问</li>
                  <li>输入后按回车或点击验证按钮</li>
                </ul>
              </div>
            </div>

            <div class="url-input-group">
              <div class="url-input-wrapper" id="urlInputWrapper">
                <span class="url-prefix">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                </span>
                <input
                  type="url"
                  id="urlInput"
                  class="url-input"
                  placeholder="https://example.com"
                  autocomplete="url"
                  spellcheck="false"
                >
                <button class="url-validate-btn" id="urlValidateBtn" title="验证网址">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                </button>
                <div class="url-status" id="urlStatus"></div>
              </div>
              <div class="url-hint" id="urlHint">
                <span class="hint-icon">&#9432;</span>
                请输入完整的网站地址，例如: <code>https://www.example.com</code>
              </div>
              <div class="url-error" id="urlError" style="display:none;"></div>
              <div class="url-success" id="urlSuccess" style="display:none;"></div>
            </div>

            <!-- 快捷示例 -->
            <div class="url-examples">
              <span class="examples-label">快捷示例：</span>
              <button class="example-chip" data-url="https://www.baidu.com">百度</button>
              <button class="example-chip" data-url="https://www.bilibili.com">哔哩哔哩</button>
              <button class="example-chip" data-url="https://www.zhihu.com">知乎</button>
              <button class="example-chip" data-url="https://www.taobao.com">淘宝</button>
            </div>
          </div>

          <!-- 步骤2：图标上传 -->
          <div class="form-section" id="section-icon">
            <div class="section-header">
              <div class="section-badge badge-green">步骤 2</div>
              <h3 class="section-heading">上传应用图标</h3>
              <button class="help-btn" data-help="icon-help" aria-label="帮助">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </button>
            </div>

            <div class="help-tooltip" id="icon-help">
              <div class="help-tooltip-arrow"></div>
              <div class="help-tooltip-content">
                <strong>图标上传说明</strong>
                <ul>
                  <li>推荐使用 512&times;512 像素的正方形图标</li>
                  <li>支持 PNG、JPG、SVG、WebP 格式</li>
                  <li>文件大小不超过 5MB</li>
                  <li>系统会自动生成各尺寸适配图标</li>
                  <li>非正方形图片会被居中裁剪</li>
                </ul>
              </div>
            </div>

            <div class="upload-area" id="uploadArea">
              <div class="upload-zone" id="uploadZone">
                <div class="upload-content" id="uploadContent">
                  <div class="upload-icon-wrap">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  </div>
                  <p class="upload-text-primary">拖拽图片到此处，或<span class="upload-underline">点击选择文件</span></p>
                  <p class="upload-text-secondary">支持 PNG / JPG / SVG / WebP 格式</p>
                </div>

                <!-- 上传预览 -->
                <div class="upload-preview" id="uploadPreview" style="display:none;">
                  <div class="preview-image-wrap">
                    <img id="previewImage" src="" alt="图标预览">
                    <div class="preview-overlay">
                      <button class="preview-replace-btn" id="replaceBtn">更换图标</button>
                    </div>
                  </div>
                  <div class="preview-info" id="previewInfo"></div>
                </div>

                <input type="file" id="iconFileInput" accept=".png,.jpg,.jpeg,.svg,.webp" hidden>
              </div>

              <!-- 上传进度条 -->
              <div class="upload-progress" id="uploadProgress" style="display:none;">
                <div class="progress-bar-track">
                  <div class="progress-bar-fill" id="progressFill"></div>
                </div>
                <span class="progress-text" id="progressText">0%</span>
              </div>

              <!-- 格式要求标注 -->
              <div class="upload-specs">
                <div class="spec-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                  <span>推荐 512&times;512px</span>
                </div>
                <div class="spec-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <span>PNG / JPG / SVG / WebP</span>
                </div>
                <div class="spec-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span>最大 5MB</span>
                </div>
              </div>
            </div>
          </div>

          <!-- 步骤3：可选配置 -->
          <div class="form-section" id="section-config">
            <div class="section-header">
              <div class="section-badge badge-purple">步骤 3</div>
              <h3 class="section-heading">应用配置 <span class="optional-tag">可选</span></h3>
              <button class="help-btn" data-help="config-help" aria-label="帮助">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </button>
            </div>

            <div class="help-tooltip" id="config-help">
              <div class="help-tooltip-arrow"></div>
              <div class="help-tooltip-content">
                <strong>应用配置说明</strong>
                <ul>
                  <li>应用名称：安装后显示在桌面图标下方的名称</li>
                  <li>包名：Android系统的唯一标识符</li>
                  <li>留空将使用默认值，不影响使用</li>
                </ul>
              </div>
            </div>

            <div class="config-fields">
              <div class="config-field">
                <label for="appName" class="config-label">
                  应用名称
                  <span class="config-label-hint">安装后显示的名称</span>
                </label>
                <input type="text" id="appName" class="config-input" placeholder="我的应用" maxlength="30">
                <span class="config-counter"><span id="appNameCount">0</span>/30</span>
              </div>
              <div class="config-field">
                <label for="packageName" class="config-label">
                  应用包名
                  <span class="config-label-hint">Android唯一标识</span>
                </label>
                <input type="text" id="packageName" class="config-input" placeholder="com.example.myapp" maxlength="80" pattern="[a-z][a-z0-9_]*(\.[a-z][a-z0-9_]*)*">
                <span class="config-counter"><span id="packageNameCount">0</span>/80</span>
              </div>
            </div>
          </div>

          <!-- 提交按钮 -->
          <div class="submit-section">
            <button class="btn-generate" id="generateBtn" disabled>
              <span class="btn-text">开始生成 APK</span>
              <span class="btn-loading" style="display:none;">
                <svg class="spinner" width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="31.4 31.4" stroke-linecap="round"/></svg>
                正在创建任务...
              </span>
            </button>
            <p class="submit-hint">预计耗时 30-60 秒，请耐心等待</p>
          </div>

        </div>

        <!-- 右侧：配置项说明面板 -->
        <aside class="creator-sidebar" id="sidebarGuide">
          <div class="sidebar-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <h3>配置项说明</h3>
          </div>

          <div class="config-list">
            <!-- 配置项1 -->
            <div class="config-item">
              <div class="config-item-header">
                <span class="config-item-name">网站地址 (URL)</span>
                <span class="config-required">必填</span>
              </div>
              <p class="config-item-purpose">指定应用内 WebView 加载的目标网页地址</p>
              <div class="config-item-example">
                <span class="example-label">示例值：</span>
                <code>https://www.example.com</code>
              </div>
              <div class="config-item-location">
                <span class="location-label">配置位置：</span>
                步骤1 &rarr; 网址输入框
              </div>
              <div class="config-item-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                必须以 http:// 或 https:// 开头；建议使用 HTTPS 协议
              </div>
            </div>

            <!-- 配置项2 -->
            <div class="config-item">
              <div class="config-item-header">
                <span class="config-item-name">应用图标</span>
                <span class="config-required">必填</span>
              </div>
              <p class="config-item-purpose">作为应用在安卓桌面显示的图标，影响用户第一印象</p>
              <div class="config-item-example">
                <span class="example-label">示例值：</span>
                <code>512&times;512px PNG图片</code>
              </div>
              <div class="config-item-location">
                <span class="location-label">配置位置：</span>
                步骤2 &rarr; 图标上传区域
              </div>
              <div class="config-item-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                推荐 512&times;512 正方形；文件 &le; 5MB；支持 PNG/JPG/SVG/WebP
              </div>
            </div>

            <!-- 配置项3 -->
            <div class="config-item">
              <div class="config-item-header">
                <span class="config-item-name">应用名称</span>
                <span class="config-optional">可选</span>
              </div>
              <p class="config-item-purpose">安装后显示在安卓桌面图标下方的名称</p>
              <div class="config-item-example">
                <span class="example-label">示例值：</span>
                <code>我的商城</code>
              </div>
              <div class="config-item-location">
                <span class="location-label">配置位置：</span>
                步骤3 &rarr; 应用名称输入框
              </div>
              <div class="config-item-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                最多30个字符；留空则自动从网址提取
              </div>
            </div>

            <!-- 配置项4 -->
            <div class="config-item">
              <div class="config-item-header">
                <span class="config-item-name">应用包名</span>
                <span class="config-optional">可选</span>
              </div>
              <p class="config-item-purpose">Android 系统识别应用的唯一标识符，用于区分不同应用</p>
              <div class="config-item-example">
                <span class="example-label">示例值：</span>
                <code>com.example.myapp</code>
              </div>
              <div class="config-item-location">
                <span class="location-label">配置位置：</span>
                步骤3 &rarr; 应用包名输入框
              </div>
              <div class="config-item-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                格式: com.xxx.xxx；仅小写字母、数字和点；留空自动生成
              </div>
            </div>

            <!-- 配置项5 -->
            <div class="config-item">
              <div class="config-item-header">
                <span class="config-item-name">签名证书</span>
                <span class="config-auto">自动</span>
              </div>
              <p class="config-item-purpose">对 APK 进行数字签名，确保应用可被安卓系统信任安装</p>
              <div class="config-item-example">
                <span class="example-label">示例值：</span>
                <code>系统自动签名 (V2)</code>
              </div>
              <div class="config-item-location">
                <span class="location-label">配置位置：</span>
                后端自动处理，无需手动配置
              </div>
              <div class="config-item-note">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                使用平台统一签名证书；如需自有证书请联系管理员
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- 构建进度弹窗 -->
  <div class="modal-overlay" id="buildModal" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h3>正在生成您的应用</h3>
        <button class="modal-close" id="modalClose">&times;</button>
      </div>
      <div class="modal-body">
        <div class="build-progress-ring">
          <svg width="120" height="120" viewBox="0 0 120 120">
            <circle cx="60" cy="60" r="54" fill="none" stroke="#E5E7EB" stroke-width="8"/>
            <circle id="progressCircle" cx="60" cy="60" r="54" fill="none" stroke="#2563EB" stroke-width="8" stroke-linecap="round" stroke-dasharray="339.292" stroke-dashoffset="339.292" transform="rotate(-90 60 60)"/>
          </svg>
          <div class="progress-ring-text">
            <span id="progressPercent">0</span><span class="percent-sign">%</span>
          </div>
        </div>

        <div class="build-steps" id="buildSteps">
          <div class="build-step" data-step="validating">
            <div class="build-step-icon pending"></div>
            <div class="build-step-info">
              <span class="build-step-name">验证网址和图标</span>
              <span class="build-step-time">预计 5 秒</span>
            </div>
          </div>
          <div class="build-step" data-step="preparing">
            <div class="build-step-icon pending"></div>
            <div class="build-step-info">
              <span class="build-step-name">准备构建环境</span>
              <span class="build-step-time">预计 8 秒</span>
            </div>
          </div>
          <div class="build-step" data-step="building">
            <div class="build-step-icon pending"></div>
            <div class="build-step-info">
              <span class="build-step-name">编译 Android 工程</span>
              <span class="build-step-time">预计 30 秒</span>
            </div>
          </div>
          <div class="build-step" data-step="signing">
            <div class="build-step-icon pending"></div>
            <div class="build-step-info">
              <span class="build-step-name">APK 签名</span>
              <span class="build-step-time">预计 8 秒</span>
            </div>
          </div>
          <div class="build-step" data-step="uploading">
            <div class="build-step-icon pending"></div>
            <div class="build-step-info">
              <span class="build-step-name">上传到服务器</span>
              <span class="build-step-time">预计 5 秒</span>
            </div>
          </div>
        </div>

        <p class="build-elapsed">已用时间: <span id="elapsedTime">00:00</span></p>
      </div>
    </div>
  </div>

  <!-- 成功弹窗 -->
  <div class="modal-overlay" id="successModal" style="display:none;">
    <div class="modal-content modal-success">
      <div class="success-checkmark">
        <svg width="80" height="80" viewBox="0 0 80 80">
          <circle cx="40" cy="40" r="36" fill="#D1FAE5" stroke="#10B981" stroke-width="2"/>
          <path class="check-path" d="M24 40 L35 51 L56 30" fill="none" stroke="#059669" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3 class="success-title">应用生成成功！</h3>
      <p class="success-desc">您的 Android 应用已准备就绪，点击下方按钮下载安装</p>
      <button class="btn-download" id="downloadBtn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载 APK 安装包
      </button>
      <div class="success-info">
        <span>文件大小: ~15MB</span>
        <span>有效期: 24小时</span>
        <span>下载次数: 5次</span>
      </div>
      <div class="success-actions">
        <button class="btn-outline" id="newBuildBtn">再做一个</button>
        <button class="btn-outline" id="closeSuccessBtn">关闭</button>
      </div>
    </div>
  </div>

  <!-- Toast 通知 -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- 页脚 -->
  <footer class="footer">
    <div class="container footer-inner">
      <p>&copy; 2024 Web2App 智能封装平台 &middot; 将网站一键转为安卓应用</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
